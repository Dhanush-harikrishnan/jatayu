NODE_ENV=development
PORT=3000

# Authentication
JWT_SECRET=super_secret_jwt_key_here

# AWS Configuration
AWS_REGION=ap-south-2
AWS_REKOGNITION_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_S3_BUCKET=secureguard-pro-evidence
AWS_SES_SOURCE_EMAIL=no-reply@yourdomain.com
ADMIN_EMAIL=admin@institution.edu

# Monitoring Thresholds
REKOGNITION_CONFIDENCE_THRESHOLD=90.0
ISOLATION_FOREST_THRESHOLD=-0.5
CORRELATION_WINDOW_MS=5000
